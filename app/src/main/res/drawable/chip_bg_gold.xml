<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#E0B450" android:endColor="#A9842F" android:angle="90" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="#FFE38A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#C9A24B" android:endColor="#6E5424" android:angle="90" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
