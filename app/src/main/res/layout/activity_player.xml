<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="true"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:bar_height="6dp"
        app:touch_target_height="56dp"
        app:scrubber_enabled_size="18dp"
        app:scrubber_dragged_size="26dp"
        app:scrubber_color="#19c37d"
        app:played_color="#19c37d"
        app:buffered_color="#8819c37d" />

    <!-- Night mode: a warm low-blue tint over the video. -->
    <View
        android:id="@+id/nightOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40FF7A00"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#B3000000"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/subBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="💬 Subtitles"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/menuBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="⋮"
            android:textColor="#ffffff"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <!-- Top-left quick controls (shown with the player controller): aspect / volume / brightness. -->
    <LinearLayout
        android:id="@+id/leftControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="64dp"
        android:layout_marginStart="20dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/aspectBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="⤢  Fit"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/volBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="🔊"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/brightBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <!-- Volume panel (toggled by 🔊). -->
    <LinearLayout
        android:id="@+id/volumePanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="120dp"
        android:layout_marginStart="20dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊  Volume"
            android:textColor="#e6edf3"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/volSeek"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:thumb="@drawable/seek_thumb"
            android:thumbOffset="0dp"
            android:max="100" />

        <TextView
            android:id="@+id/muteBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="🔇  Mute"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <!-- Brightness panel (toggled by ☀). -->
    <LinearLayout
        android:id="@+id/brightnessPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="120dp"
        android:layout_marginStart="20dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀  Brightness"
            android:textColor="#e6edf3"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/brightSeek"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:thumb="@drawable/seek_thumb"
            android:thumbOffset="0dp"
            android:max="100" />

        <TextView
            android:id="@+id/nightBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="🌙  Night mode"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>
</FrameLayout>
