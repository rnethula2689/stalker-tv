<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/window_bg"
    android:padding="20dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⏺  Recordings"
        android:textColor="#19c37d"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#9fb0c0"
        android:textSize="15sp"
        android:visibility="gone"
        android:text="No recordings yet.\n\nOpen Live TV or a catch-up programme, go fullscreen, and tap the ⏺ record button." />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/removeSelBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="☑  Delete selected"
            android:textColor="#e6edf3"
            android:textSize="15sp"
            android:gravity="center"
            android:padding="14dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg"
            android:visibility="gone" />

        <TextView
            android:id="@+id/removeAllBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗑  Delete all"
            android:textColor="#ff6b6b"
            android:textSize="15sp"
            android:gravity="center"
            android:padding="14dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
