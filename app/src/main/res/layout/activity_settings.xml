<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/window_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙  Settings"
            android:textColor="#19c37d"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/rowProviders"
            style="@style/SettingsRow"
            android:text="📡   IPTV configuration" />

        <TextView
            android:id="@+id/rowProfiles"
            style="@style/SettingsRow"
            android:text="👤   Profiles" />

        <TextView
            android:id="@+id/rowPersonalization"
            style="@style/SettingsRow"
            android:text="✨   Personalization" />

        <TextView
            android:id="@+id/rowRemote"
            style="@style/SettingsRow"
            android:text="🎮   Remote control (key mapping)" />

        <TextView
            android:id="@+id/rowPin"
            style="@style/SettingsRow"
            android:text="🔒   Parental PIN" />

        <TextView
            android:id="@+id/rowPlayback"
            style="@style/SettingsRow"
            android:text="🎚   Playback settings" />

        <TextView
            android:id="@+id/rowSleep"
            style="@style/SettingsRow"
            android:text="⏲   Sleep timer" />

        <TextView
            android:id="@+id/rowStorage"
            style="@style/SettingsRow"
            android:text="🗄   Storage" />

        <TextView
            android:id="@+id/rowSubs"
            style="@style/SettingsRow"
            android:text="💬   Subtitles" />

        <TextView
            android:id="@+id/rowEpg"
            style="@style/SettingsRow"
            android:text="📺   TV Guide (EPG)" />

        <TextView
            android:id="@+id/rowUpdates"
            style="@style/SettingsRow"
            android:text="📥   App updates" />

        <TextView
            android:id="@+id/rowBackup"
            style="@style/SettingsRow"
            android:text="⬆   Sync &amp; Backup" />

        <TextView
            android:id="@+id/rowDiag"
            style="@style/SettingsRow"
            android:text="🩺   Troubleshooting" />

        <TextView
            android:id="@+id/rowHelp"
            style="@style/SettingsRow"
            android:text="❓   User guide" />

        <TextView
            android:id="@+id/rowAbout"
            style="@style/SettingsRow"
            android:text="ℹ️   About" />

        <TextView
            android:id="@+id/rowExit"
            style="@style/SettingsRow"
            android:text="✖   Exit" />
    </LinearLayout>
</ScrollView>
