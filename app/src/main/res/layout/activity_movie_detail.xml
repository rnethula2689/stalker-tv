<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F14">

    <!-- Blurred-look backdrop (low-res upscaled) + dark scrim -->
    <ImageView
        android:id="@+id/backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.5"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="40dp">

            <ImageView
                android:id="@+id/poster"
                android:layout_width="140dp"
                android:layout_height="210dp"
                android:scaleType="centerCrop"
                android:background="#22FFFFFF"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="#ffffff"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="#b9c4d0"
                android:textStyle="italic"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/playBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="▶   Play"
                android:textColor="#0B0F14"
                android:textSize="17sp"
                android:textStyle="bold"
                android:paddingHorizontal="40dp"
                android:paddingVertical="12dp"
                android:background="@drawable/play_pill"
                android:focusable="true"
                android:clickable="true" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView android:id="@+id/favBtn"
                    android:layout_width="54dp" android:layout_height="54dp"
                    android:layout_marginHorizontal="8dp"
                    android:gravity="center" android:text="☆" android:textSize="22sp"
                    android:textColor="#ffffff" android:background="@drawable/icon_circle"
                    android:focusable="true" android:clickable="true" />

                <TextView android:id="@+id/laterBtn"
                    android:layout_width="54dp" android:layout_height="54dp"
                    android:layout_marginHorizontal="8dp"
                    android:gravity="center" android:text="🕒" android:textSize="20sp"
                    android:textColor="#ffffff" android:background="@drawable/icon_circle"
                    android:focusable="true" android:clickable="true" />

                <TextView android:id="@+id/dlBtn"
                    android:layout_width="54dp" android:layout_height="54dp"
                    android:layout_marginHorizontal="8dp"
                    android:gravity="center" android:text="⬇" android:textSize="20sp"
                    android:textColor="#ffffff" android:background="@drawable/icon_circle"
                    android:focusable="true" android:clickable="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textColor="#cfd8e3"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="#dfe7ef"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.15"
                android:maxLines="5"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/moreBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="More"
                android:textColor="#19c37d"
                android:textStyle="bold"
                android:padding="6dp"
                android:focusable="true"
                android:clickable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/trailersHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Trailers"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/trailersScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/trailersRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/castHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Cast"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/castScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/castRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
