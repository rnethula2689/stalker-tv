<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlc"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Software dim (TV brightness can't touch the panel backlight, so we darken the picture). -->
    <View
        android:id="@+id/dimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha="0" />

    <!-- Night mode: a warm low-blue tint over the video (controls stay above this, undimmed). -->
    <View
        android:id="@+id/nightOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40FF7A00"
        android:visibility="gone" />

    <!-- "Now playing" bar (STB-style): the current programme + a progress slider + what's next.
         Sits at the bottom, shown briefly with the controls; never covers the top icons.
         Replaces the old full-height side EPG list. -->
    <LinearLayout
        android:id="@+id/nowBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#cc000000"
        android:paddingHorizontal="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/nowTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:ellipsize="end"
                android:textColor="#ffffff"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="" />

            <TextView
                android:id="@+id/nowChHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="#8b97a5"
                android:textSize="11sp"
                android:text="▲ ▼ channel" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/nowStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="62dp"
                android:textColor="#9fb0c0"
                android:textSize="11sp"
                android:text="" />

            <ProgressBar
                android:id="@+id/nowProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:max="1000"
                android:progress="0" />

            <TextView
                android:id="@+id/nowEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="62dp"
                android:gravity="end"
                android:textColor="#9fb0c0"
                android:textSize="11sp"
                android:text="" />
        </LinearLayout>

        <TextView
            android:id="@+id/nowNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:textColor="#9fb0c0"
            android:textSize="12sp"
            android:text="" />
    </LinearLayout>

    <TextView
        android:id="@+id/status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#e6edf3"
        android:textSize="16sp"
        android:text="Loading…" />

    <!-- Top bar: channel title + overflow menu. Shown briefly on key/tap. -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#cc000000"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="" />

        <TextView
            android:id="@+id/multiBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="⊞"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/pipBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="⧉"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/recBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="⏺"
            android:textColor="#ff5a5a"
            android:textSize="16sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/aspectBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="⤢ Fit"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/speedBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="1×"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/volBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="🔊"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/brightBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="☀"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/tsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="⏪ Rewind"
            android:textSize="15sp"
            android:textColor="#ffffff"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/menuBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⋮"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <TextView
        android:id="@+id/hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_margin="14dp"
        android:background="#99000000"
        android:padding="8dp"
        android:textColor="#e6edf3"
        android:textSize="13sp"
        android:visibility="gone"
        android:text="▲ / ▼  change channel" />

    <!-- Catch-up / timeshift transport bar. Two rows: a full-width scrub slider on top (so the
         slider stays long and easy to grab even in portrait), transport buttons below. -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#cc000000"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <!-- Row 1: current time · full-width slider · total time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/posText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="13sp"
                android:textColor="#e6edf3"
                android:minWidth="52dp"
                android:gravity="center" />

            <SeekBar
                android:id="@+id/seek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:minHeight="56dp"
                android:paddingHorizontal="4dp"
                android:paddingVertical="14dp"
                android:thumb="@drawable/seek_thumb"
                android:thumbOffset="0dp"
                android:max="1000" />

            <TextView
                android:id="@+id/durText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="13sp"
                android:textColor="#e6edf3"
                android:minWidth="52dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Row 2: skip back · play/pause · skip forward · (spacer) · LIVE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="2dp">

            <TextView
                android:id="@+id/rewindBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="⏪"
                android:textSize="22sp"
                android:textColor="#ffffff"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />

            <TextView
                android:id="@+id/playBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="⏸"
                android:textSize="22sp"
                android:textColor="#ffffff"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />

            <TextView
                android:id="@+id/forwardBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏩"
                android:textSize="22sp"
                android:textColor="#ffffff"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/liveBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="● LIVE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#ff5a5a"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:visibility="gone"
                android:background="@drawable/item_bg" />
        </LinearLayout>
    </LinearLayout>

    <!-- Volume panel (toggled by 🔊). -->
    <LinearLayout
        android:id="@+id/volumePanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="58dp"
        android:layout_marginEnd="14dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/volLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊  Volume"
            android:textColor="#e6edf3"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/volSeek"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:thumb="@drawable/seek_thumb"
            android:thumbOffset="0dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:max="100" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="◀ ▶ adjust · OK mute · Back close"
            android:textColor="#7a8a9a"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/muteBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="🔇  Mute"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <!-- Brightness panel (toggled by ☀). -->
    <LinearLayout
        android:id="@+id/brightnessPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="58dp"
        android:layout_marginEnd="14dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/brightLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀  Brightness"
            android:textColor="#e6edf3"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/brightSeek"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:thumb="@drawable/seek_thumb"
            android:thumbOffset="0dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:max="100" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="◀ ▶ adjust · OK night · Back close"
            android:textColor="#7a8a9a"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/nightBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="🌙  Night mode"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <!-- Recording indicator: stays visible (even when the bar is hidden) while recording. -->
    <TextView
        android:id="@+id/recDot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:text="● REC"
        android:textColor="#ff3b30"
        android:textStyle="bold"
        android:textSize="14sp"
        android:background="#99000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:visibility="gone" />
</FrameLayout>
