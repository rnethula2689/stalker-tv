<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlc"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Night mode: a warm low-blue tint over the video (controls stay above this, undimmed). -->
    <View
        android:id="@+id/nightOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40FF7A00"
        android:visibility="gone" />

    <TextView
        android:id="@+id/status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#e6edf3"
        android:textSize="16sp"
        android:text="Loading…" />

    <!-- Top bar: channel title + overflow menu. Shown briefly on key/tap. -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#cc000000"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="" />

        <TextView
            android:id="@+id/tsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="⏪ Rewind"
            android:textSize="15sp"
            android:textColor="#ffffff"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/menuBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⋮"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <TextView
        android:id="@+id/hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_margin="14dp"
        android:background="#99000000"
        android:padding="8dp"
        android:textColor="#e6edf3"
        android:textSize="13sp"
        android:visibility="gone"
        android:text="▲ / ▼  change channel" />

    <!-- Catch-up / timeshift transport bar. Two rows: a full-width scrub slider on top (so the
         slider stays long and easy to grab even in portrait), transport buttons below. -->
    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#cc000000"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <!-- Row 1: current time · full-width slider · total time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/posText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="13sp"
                android:textColor="#e6edf3"
                android:minWidth="52dp"
                android:gravity="center" />

            <SeekBar
                android:id="@+id/seek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:minHeight="56dp"
                android:paddingHorizontal="4dp"
                android:paddingVertical="14dp"
                android:thumb="@drawable/seek_thumb"
                android:thumbOffset="0dp"
                android:max="1000" />

            <TextView
                android:id="@+id/durText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="13sp"
                android:textColor="#e6edf3"
                android:minWidth="52dp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Row 2: skip back · play/pause · skip forward · (spacer) · LIVE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="2dp">

            <TextView
                android:id="@+id/rewindBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="⏪"
                android:textSize="22sp"
                android:textColor="#ffffff"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />

            <TextView
                android:id="@+id/playBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="⏸"
                android:textSize="22sp"
                android:textColor="#ffffff"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />

            <TextView
                android:id="@+id/forwardBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏩"
                android:textSize="22sp"
                android:textColor="#ffffff"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/liveBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="● LIVE"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#ff5a5a"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:visibility="gone"
                android:background="@drawable/item_bg" />
        </LinearLayout>
    </LinearLayout>

    <!-- Top-left quick controls (shown on tap with the bar): aspect / volume / brightness. -->
    <LinearLayout
        android:id="@+id/leftControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="62dp"
        android:layout_marginStart="14dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/aspectBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="⤢  Fit"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/volBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="🔊"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/brightBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <!-- Volume panel (toggled by 🔊). -->
    <LinearLayout
        android:id="@+id/volumePanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="118dp"
        android:layout_marginStart="14dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊  Volume"
            android:textColor="#e6edf3"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/volSeek"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:thumb="@drawable/seek_thumb"
            android:thumbOffset="0dp"
            android:max="100" />

        <TextView
            android:id="@+id/muteBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="🔇  Mute"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <!-- Brightness panel (toggled by ☀). -->
    <LinearLayout
        android:id="@+id/brightnessPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="118dp"
        android:layout_marginStart="14dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀  Brightness"
            android:textColor="#e6edf3"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/brightSeek"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:thumb="@drawable/seek_thumb"
            android:thumbOffset="0dp"
            android:max="100" />

        <TextView
            android:id="@+id/nightBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="🌙  Night mode"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>
</FrameLayout>
