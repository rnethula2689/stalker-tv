<?xml version="1.0" encoding="utf-8"?>
<!-- One Multi-view pane: a libVLC surface with a name + audio badge and an "add" hint when empty. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="2dp"
    android:focusable="true"
    android:clickable="true"
    android:background="@drawable/preview_bg"
    android:foreground="@drawable/poster_focus">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/video"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/paneEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="＋\nAdd channel"
        android:gravity="center"
        android:textColor="#9fb0c0"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/paneName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="6dp"
        android:background="#99000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:textColor="#e6edf3"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:visibility="gone" />

    <TextView
        android:id="@+id/paneAudio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:text="🔇"
        android:textSize="16sp"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:background="#99000000"
        android:visibility="gone" />
</FrameLayout>
