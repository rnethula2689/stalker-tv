<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/window_bg"
    android:padding="20dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🕒  Watch Later"
        android:textColor="#19c37d"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:baselineAligned="false">

        <EditText
            android:id="@+id/search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search Watch Later…"
            android:textColorHint="#5a6675"
            android:textColor="#e6edf3"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text" />

        <TextView
            android:id="@+id/sortBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="⇅  Newest"
            android:textColor="#e6edf3"
            android:textSize="14sp"
            android:padding="12dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />

        <TextView
            android:id="@+id/exportBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="↗  Export"
            android:textColor="#e6edf3"
            android:textSize="14sp"
            android:padding="12dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg" />
    </LinearLayout>

    <TextView
        android:id="@+id/empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#9fb0c0"
        android:textSize="15sp"
        android:visibility="gone"
        android:text="Nothing saved for later yet.\n\nOpen a movie or episode and choose “🕒 Watch later”." />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/removeSelBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="☑  Remove selected"
            android:textColor="#e6edf3"
            android:textSize="15sp"
            android:gravity="center"
            android:padding="14dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg"
            android:visibility="gone" />

        <TextView
            android:id="@+id/removeAllBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗑  Remove all"
            android:textColor="#ff6b6b"
            android:textSize="15sp"
            android:gravity="center"
            android:padding="14dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
