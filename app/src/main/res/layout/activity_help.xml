<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/window_bg"
    android:padding="20dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Guide"
        android:textColor="#19c37d"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/savePdfBtn"
            style="@style/SettingsRow"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="⬇  Save as PDF" />

        <TextView
            android:id="@+id/sharePdfBtn"
            style="@style/SettingsRow"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="↗  Share PDF" />
    </LinearLayout>

    <TextView
        android:id="@+id/guide"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:padding="6dp"
        android:textColor="#e6edf3"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.1"
        android:fontFamily="monospace"
        android:text="" />
</LinearLayout>
