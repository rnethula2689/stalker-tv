<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/window_bg"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⬇  Downloads"
        android:textColor="#19c37d"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#9fb0c0"
        android:textSize="15sp"
        android:visibility="gone"
        android:text="No downloads yet.\n\nOpen a movie or episode and choose “Download for offline”." />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/removeAllBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="🗑  Remove all downloads"
        android:textColor="#ff6b6b"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="14dp"
        android:focusable="true"
        android:clickable="true"
        android:background="@drawable/item_bg"
        android:visibility="gone" />
</LinearLayout>
