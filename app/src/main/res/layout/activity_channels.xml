<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/window_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#19c37d"
                android:textSize="22sp"
                android:textStyle="bold"
                android:text="Stalker TV" />

            <TextView
                android:id="@+id/searchBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="22sp"
                android:padding="10dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />

            <TextView
                android:id="@+id/reloadBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="🔄"
                android:textSize="22sp"
                android:padding="10dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />

            <TextView
                android:id="@+id/sortBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="⇅ New"
                android:textSize="15sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp"
                android:focusable="true"
                android:clickable="true"
                android:visibility="gone"
                android:background="@drawable/item_bg" />

            <TextView
                android:id="@+id/menuBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="⋮"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/searchRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/search"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search…"
                android:textColorHint="#5a6675"
                android:textColor="#e6edf3"
                android:singleLine="true"
                android:imeOptions="actionSearch" />

            <TextView
                android:id="@+id/clearBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="✕"
                android:textSize="20sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/item_bg" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/azBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#e6edf3"
            android:textSize="16sp"
            android:text="" />

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/list"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>

    <!-- Loading splash: covers the screen while the portal connects / refreshes. -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/window_bg"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_launcher"
            android:contentDescription="Stalker TV" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Stalker TV"
            android:textColor="#19c37d"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/loadingBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="300dp"
            android:layout_height="14dp"
            android:layout_marginTop="28dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_horizontal_green" />

        <TextView
            android:id="@+id/loadingPct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="0%"
            android:textColor="#19c37d"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/loadingMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Loading…"
            android:textColor="#9fb0c0"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
