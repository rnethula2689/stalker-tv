<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F14">

    <ImageView
        android:id="@+id/backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.5"
        android:contentDescription="@null" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#aa000000" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="40dp"
            android:paddingTop="28dp"
            android:paddingBottom="36dp">

            <!-- Top: poster on the left, info on the right -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/poster"
                    android:layout_width="150dp"
                    android:layout_height="225dp"
                    android:scaleType="centerCrop"
                    android:background="#22FFFFFF"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="28dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#ffffff"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tagline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#b9c4d0"
                        android:textStyle="italic"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#cfd8e3"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/playBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▶   Play"
                            android:textColor="#0B0F14"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="34dp"
                            android:paddingVertical="11dp"
                            android:background="@drawable/play_pill"
                            android:focusable="true"
                            android:clickable="true" />

                        <TextView android:id="@+id/favBtn"
                            android:layout_width="50dp" android:layout_height="50dp"
                            android:layout_marginStart="14dp"
                            android:gravity="center" android:text="☆" android:textSize="20sp"
                            android:textColor="#ffffff" android:background="@drawable/icon_circle"
                            android:focusable="true" android:clickable="true" />

                        <TextView android:id="@+id/laterBtn"
                            android:layout_width="50dp" android:layout_height="50dp"
                            android:layout_marginStart="10dp"
                            android:gravity="center" android:text="＋" android:textSize="24sp"
                            android:textColor="#ffffff" android:background="@drawable/icon_circle"
                            android:focusable="true" android:clickable="true" />

                        <TextView android:id="@+id/dlBtn"
                            android:layout_width="50dp" android:layout_height="50dp"
                            android:layout_marginStart="10dp"
                            android:gravity="center" android:text="📥" android:textSize="18sp"
                            android:textColor="#ffffff" android:background="@drawable/icon_circle"
                            android:focusable="true" android:clickable="true" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/overview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="#dfe7ef"
                        android:textSize="15sp"
                        android:lineSpacingMultiplier="1.15"
                        android:maxLines="4"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/moreBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="More"
                        android:textColor="#19c37d"
                        android:textStyle="bold"
                        android:padding="6dp"
                        android:focusable="true"
                        android:clickable="true"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/seasonBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Season 1  ▾"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingHorizontal="22dp"
                android:paddingVertical="10dp"
                android:background="@drawable/icon_circle"
                android:focusable="true"
                android:clickable="true"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/episodesScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/episodesRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/trailersHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Trailers"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/trailersScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/trailersRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/castHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Cast"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/castScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/castRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
